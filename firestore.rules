rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    
    // ===============================================================
    // Assumed Data Model
    // ===============================================================
    //
    // Collection: users
    // Document ID: {userId} (matches auth.uid)
    // Fields:
    //   - uid: string (required)
    //   - displayName: string (required)
    //   - photoURL: string (optional)
    //   - totalPoints: number (optional)
    //   - correctResults: number (optional)
    //   - correctWinners: number (optional)
    //
    // Collection: users/{userId}/predictions
    // Document ID: {matchId}
    // Fields:
    //   - matchId: string (required)
    //   - homeScore: number (required)
    //   - awayScore: number (required)
    //   - updatedAt: timestamp (optional)
    //
    // ===============================================================

    // ===============================================================
    // Helper Functions
    // ===============================================================
    
    function isAuthenticated() {
      return request.auth != null;
    }

    function isOwner(userId) {
      return isAuthenticated() && request.auth.uid == userId;
    }

    function isAdmin() {
      return isAuthenticated() && 
             (request.auth.token.email == "melaniagonzalez@gmail.com");
    }

    function isValidUser(data) {
      return data.keys().hasAll(['uid', 'displayName']);
    }

    function isValidPrediction(data) {
      return data.keys().hasAll(['matchId']);
    }

    // ===============================================================
    // Rules
    // ===============================================================

    match /{document=**} {
      allow read, write: if true;
    }
  }
}

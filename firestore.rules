rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // Global Safety Net (default deny)
    match /{document=**} {
      allow read, write: if false;
    }

    // Helper functions
    function isSignedIn() {
      return request.auth != null;
    }

    // Checking if the signed-in user is a super administrator
    function isSuperAdmin() {
      return isSignedIn() && (
        request.auth.token.get('email', '').lower() == "melaniagonzalez@gmail.com" ||
        (exists(/databases/$(database)/documents/users/$(request.auth.uid)) && 
         get(/databases/$(database)/documents/users/$(request.auth.uid)).data.get('adminRole', 'none') == "superadmin") ||
        (exists(/databases/$(database)/documents/admins/$(request.auth.token.get('email', 'default_non_existent').lower())) && 
         get(/databases/$(database)/documents/admins/$(request.auth.token.get('email', 'default_non_existent').lower())).data.get('role', 'none') == "superadmin") ||
        (exists(/databases/$(database)/documents/admins/$(request.auth.token.get('email', 'default_non_existent'))) && 
         get(/databases/$(database)/documents/admins/$(request.auth.token.get('email', 'default_non_existent'))).data.get('role', 'none') == "superadmin")
      );
    }

    // Checking if the signed-in user is an administrator
    function isAdmin() {
      return isSignedIn() && (
        isSuperAdmin() ||
        request.auth.token.get('email', '').lower() == "melaniagonzalez@gmail.com" || 
        request.auth.token.get('email', '').matches('(?i).*admin.*') ||
        (exists(/databases/$(database)/documents/users/$(request.auth.uid)) && 
         get(/databases/$(database)/documents/users/$(request.auth.uid)).data.get('isAdmin', false) == true) ||
        (exists(/databases/$(database)/documents/adminRequests/$(request.auth.uid)) && 
         get(/databases/$(database)/documents/adminRequests/$(request.auth.uid)).data.get('status', 'none') == "approved") ||
        (exists(/databases/$(database)/documents/admins/$(request.auth.token.get('email', 'default_non_existent').lower()))) ||
        (exists(/databases/$(database)/documents/admins/$(request.auth.token.get('email', 'default_non_existent'))))
      );
    }

    // Validate ID length and characters
    function isValidId(id) {
      return id is string && id.size() <= 128 && id.matches('^[a-zA-Z0-9_\\-]+$');
    }

    function hasCurrentVersion(data) {
      return true;
    }

    // Rules for User profiles (which now represent both Admins and Participant profiles managed by Admins)
    match /users/{userId} {
      allow read: if true;
      allow write: if isAdmin() && isValidId(userId);
      allow create: if isSignedIn() && userId == request.auth.uid && isValidId(userId) && (
        request.resource.data.isAdmin == false &&
        (!('adminRole' in request.resource.data) || request.resource.data.adminRole == 'none') &&
        (!('adminRequestStatus' in request.resource.data) || request.resource.data.adminRequestStatus == 'none' || request.resource.data.adminRequestStatus == 'pending') &&
        hasCurrentVersion(request.resource.data)
      );
      allow update: if isValidId(userId) && (
        isAdmin() ||
        (
          hasCurrentVersion(request.resource.data) &&
          (
            (isSignedIn() && userId == request.auth.uid && (
              !request.resource.data.diff(resource.data).affectedKeys().hasAny(['isAdmin', 'adminRole', 'adminRequestStatus', 'otherExtraPoints'])
            )) ||
            ((userId.matches('^p_.*') || resource.data.get('isParticipant', false) == true) && (
              !request.resource.data.diff(resource.data).affectedKeys().hasAny(['isAdmin', 'adminRole', 'adminRequestStatus', 'isParticipant', 'leagueId', 'email', 'searchEmail', 'otherExtraPoints'])
            )) ||
            (
              // Allow the creator/administrator of the league to update participant scores and stats
              isSignedIn() &&
              'leagueId' in resource.data &&
              exists(/databases/$(database)/documents/leagues/$(resource.data.leagueId)) &&
              get(/databases/$(database)/documents/leagues/$(resource.data.leagueId)).data.creatorId == request.auth.uid &&
              request.resource.data.diff(resource.data).affectedKeys().hasOnly(['totalPoints', 'correctResults', 'correctWinners', 'extraPoints', 'otherExtraPoints', 'lastUpdatedAt', 'appVersion'])
            )
          )
        )
      );
      
      // Predictions subcollection
      match /predictions/{matchId} {
        allow read: if true;
        allow write: if (
          isAdmin() || 
          (
            (
              (isSignedIn() && userId == request.auth.uid) || 
              userId.matches('^p_.*') || 
              (exists(/databases/$(database)/documents/users/$(userId)) && 
               get(/databases/$(database)/documents/users/$(userId)).data.get('isParticipant', false) == true)
            ) && hasCurrentVersion(request.resource.data)
          )
        ) && isValidId(matchId);
      }
    }

    // Rules for Leagues/Quinielas
    match /leagues/{leagueId} {
      allow read: if true;
      allow write: if isAdmin() && isValidId(leagueId);
    }

    // Rules for General Configurations (Extra Points by Competition)
    match /configurations/{configId} {
      allow read: if true;
      allow write: if isAdmin() && isValidId(configId);
    }

    // Rules for Admins Configuration
    match /admins/{adminId} {
      allow read: if isSignedIn() && (
        isSuperAdmin() ||
        adminId == request.auth.token.get('email', '').lower() || adminId == request.auth.token.get('email', '')
      );
      allow write: if isSuperAdmin();
    }

    // Rules for Admin Requests
    match /adminRequests/{requestId} {
      allow read: if isSignedIn() && (
        isSuperAdmin() ||
        requestId == request.auth.uid
      );
      allow create: if isSignedIn() && (
        requestId == request.auth.uid &&
        request.resource.data.uid == request.auth.uid &&
        (
          request.auth.token.get('email', '') == '' ||
          request.resource.data.email == request.auth.token.get('email', '')
        )
      );
      allow update: if isSignedIn() && (
        isSuperAdmin() ||
        (requestId == request.auth.uid && request.resource.data.diff(resource.data).affectedKeys().hasOnly(['notified']))
      );
      allow delete: if isSuperAdmin();
    }

    // Cached competition data with public read and authenticated write
    match /competitions/{compId} {
      allow read: if true;
      allow write: if isSignedIn() && isValidId(compId);
    }

    // Sintered actual results
    match /results/{matchId} {
      allow read: if isSignedIn();
      allow write: if isAdmin() && isValidId(matchId);
    }

    // Rules for Contact Requests
    match /contactRequests/{requestId} {
      allow create: if isValidId(requestId) &&
                    request.resource.data.id == requestId &&
                    request.resource.data.name is string &&
                    request.resource.data.name.size() > 0 &&
                    request.resource.data.name.size() <= 100 &&
                    request.resource.data.email is string &&
                    request.resource.data.email.size() > 0 &&
                    request.resource.data.email.size() <= 100 &&
                    request.resource.data.phone is string &&
                    request.resource.data.phone.size() > 0 &&
                    request.resource.data.phone.size() <= 30;
      allow read: if isAdmin();
    }

    // Rules for Backups
    match /backups/{backupId} {
      allow read: if true;
      allow write: if isSuperAdmin();
    }
  }
}

rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // Global Safety Net (default deny)
    match /{document=**} {
      allow read, write: if false;
    }

    // Helper functions
    function isSignedIn() {
      return request.auth != null;
    }

    // Checking if the signed-in user is an administrator
    function isAdmin() {
      return isSignedIn() && (
        request.auth.token.email == "melaniagonzalez@gmail.com" || 
        request.auth.token.email.matches('(?i).*admin.*')
      );
    }

    // Validate ID length and characters
    function isValidId(id) {
      return id is string && id.size() <= 128 && id.matches('^[a-zA-Z0-9_\\-]+$');
    }

    // Rules for User profiles (which now represent both Admins and Participant profiles managed by Admins)
    match /users/{userId} {
      allow read: if true;
      allow write: if isAdmin() && isValidId(userId);
      
      // Predictions subcollection
      match /predictions/{matchId} {
        allow read: if true;
        allow write: if isAdmin() && isValidId(matchId);
      }
    }

    // Rules for Leagues/Quinielas
    match /leagues/{leagueId} {
      allow read: if true;
      allow write: if isAdmin() && isValidId(leagueId);
    }

    // Rules for Admins Configuration
    match /admins/{adminId} {
      allow read: if isSignedIn() && (
        request.auth.token.email == "melaniagonzalez@gmail.com" ||
        resource == null ||
        resource.data.email.lower() == request.auth.token.email.lower()
      );
      allow write: if isSignedIn() && request.auth.token.email == "melaniagonzalez@gmail.com";
    }

    // Rules for Admin Requests
    match /adminRequests/{requestId} {
      allow read: if isSignedIn() && (
        request.auth.token.email == "melaniagonzalez@gmail.com" ||
        requestId == request.auth.uid
      );
      allow create: if isSignedIn() && (
        requestId == request.auth.uid &&
        request.resource.data.uid == request.auth.uid &&
        request.resource.data.email.lower() == request.auth.token.email.lower()
      );
      allow update: if isSignedIn() && (
        request.auth.token.email == "melaniagonzalez@gmail.com" ||
        (requestId == request.auth.uid && request.resource.data.diff(resource.data).affectedKeys().hasOnly(['notified']))
      );
      allow delete: if isSignedIn() && request.auth.token.email == "melaniagonzalez@gmail.com";
    }

    // Sintered actual results
    match /results/{matchId} {
      allow read: if isSignedIn();
      allow write: if isAdmin() && isValidId(matchId);
    }
  }
}

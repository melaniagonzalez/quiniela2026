rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // Global Safety Net (default deny)
    match /{document=**} {
      allow read, write: if false;
    }

    // Helper functions
    function isSignedIn() {
      return request.auth != null;
    }

    // Checking if the signed-in user is a super administrator
    function isSuperAdmin() {
      return isSignedIn() && (
        ('email' in request.auth.token && request.auth.token.email == "melaniagonzalez@gmail.com") ||
        (exists(/databases/$(database)/documents/users/$(request.auth.uid)) && 
         get(/databases/$(database)/documents/users/$(request.auth.uid)).data.get('adminRole', 'none') == "superadmin") ||
        ('email' in request.auth.token && (
          exists(/databases/$(database)/documents/admins/$(request.auth.token.email.lower())) && 
          get(/databases/$(database)/documents/admins/$(request.auth.token.email.lower())).data.get('role', 'none') == "superadmin"
        )) ||
        ('email' in request.auth.token && (
          exists(/databases/$(database)/documents/admins/$(request.auth.token.email)) && 
          get(/databases/$(database)/documents/admins/$(request.auth.token.email)).data.get('role', 'none') == "superadmin"
        ))
      );
    }

    // Checking if the signed-in user is an administrator
    function isAdmin() {
      return isSignedIn() && (
        isSuperAdmin() ||
        ('email' in request.auth.token && request.auth.token.email == "melaniagonzalez@gmail.com") || 
        ('email' in request.auth.token && request.auth.token.email.matches('(?i).*admin.*')) ||
        (exists(/databases/$(database)/documents/users/$(request.auth.uid)) && 
         get(/databases/$(database)/documents/users/$(request.auth.uid)).data.get('isAdmin', false) == true) ||
        (exists(/databases/$(database)/documents/adminRequests/$(request.auth.uid)) && 
         get(/databases/$(database)/documents/adminRequests/$(request.auth.uid)).data.get('status', 'none') == "approved") ||
        ('email' in request.auth.token && (
          exists(/databases/$(database)/documents/admins/$(request.auth.token.email.lower()))
        )) ||
        ('email' in request.auth.token && (
          exists(/databases/$(database)/documents/admins/$(request.auth.token.email))
        ))
      );
    }

    // Validate ID length and characters
    function isValidId(id) {
      return id is string && id.size() <= 128 && id.matches('^[a-zA-Z0-9_\\-]+$');
    }

    // Rules for User profiles (which now represent both Admins and Participant profiles managed by Admins)
    match /users/{userId} {
      allow read: if true;
      allow write: if isAdmin() && isValidId(userId);
      allow create: if isSignedIn() && userId == request.auth.uid && isValidId(userId) && (
        request.resource.data.isAdmin == false &&
        (!('adminRole' in request.resource.data) || request.resource.data.adminRole == 'none') &&
        (!('adminRequestStatus' in request.resource.data) || request.resource.data.adminRequestStatus == 'none' || request.resource.data.adminRequestStatus == 'pending')
      );
      allow update: if isValidId(userId) && (
        (isSignedIn() && userId == request.auth.uid && (
          !request.resource.data.diff(resource.data).affectedKeys().hasAny(['isAdmin', 'adminRole', 'adminRequestStatus'])
        )) ||
        ((userId.matches('^p_.*') || resource.data.get('isParticipant', false) == true) && (
          !request.resource.data.diff(resource.data).affectedKeys().hasAny(['isAdmin', 'adminRole', 'adminRequestStatus', 'isParticipant', 'leagueId', 'email', 'searchEmail'])
        ))
      );
      
      // Predictions subcollection
      match /predictions/{matchId} {
        allow read: if true;
        allow write: if (
          isAdmin() || 
          (isSignedIn() && userId == request.auth.uid) || 
          userId.matches('^p_.*') || 
          (exists(/databases/$(database)/documents/users/$(userId)) && 
           get(/databases/$(database)/documents/users/$(userId)).data.get('isParticipant', false) == true)
        ) && isValidId(matchId);
      }
    }

    // Rules for Leagues/Quinielas
    match /leagues/{leagueId} {
      allow read: if true;
      allow write: if isAdmin() && isValidId(leagueId);
    }

    // Rules for Admins Configuration
    match /admins/{adminId} {
      allow read: if isSignedIn() && (
        isSuperAdmin() ||
        ('email' in request.auth.token && adminId == request.auth.token.email) ||
        ('email' in request.auth.token && adminId == request.auth.token.email.lower())
      );
      allow write: if isSuperAdmin();
    }

    // Rules for Admin Requests
    match /adminRequests/{requestId} {
      allow read: if isSignedIn() && (
        isSuperAdmin() ||
        requestId == request.auth.uid
      );
      allow create: if isSignedIn() && (
        requestId == request.auth.uid &&
        request.resource.data.uid == request.auth.uid &&
        (
          !('email' in request.auth.token) ||
          request.resource.data.email == request.auth.token.email
        )
      );
      allow update: if isSignedIn() && (
        isSuperAdmin() ||
        (requestId == request.auth.uid && request.resource.data.diff(resource.data).affectedKeys().hasOnly(['notified']))
      );
      allow delete: if isSuperAdmin();
    }

    // Sintered actual results
    match /results/{matchId} {
      allow read: if isSignedIn();
      allow write: if isAdmin() && isValidId(matchId);
    }
  }
}

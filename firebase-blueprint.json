{
  "entities": {
    "UserProfile": {
      "title": "UserProfile",
      "description": "Información del usuario y su puntuación en la quiniela",
      "type": "object",
      "properties": {
        "uid": { "type": "string", "description": "ID único del usuario" },
        "displayName": { "type": "string", "description": "Nombre visible del usuario" },
        "email": { "type": "string", "description": "Correo del usuario" },
        "searchName": { "type": "string", "description": "Nombre en minúsculas para búsquedas" },
        "searchEmail": { "type": "string", "description": "Correo en minúsculas para búsquedas" },
        "photoURL": { "type": "string", "description": "URL de la foto de perfil" },
        "totalPoints": { "type": "number", "description": "Puntos totales acumulados" },
        "correctResults": { "type": "number", "description": "Número de resultados exactos acertados" },
        "correctWinners": { "type": "number", "description": "Número de ganadores acertados" }
      },
      "required": ["uid", "displayName"]
    },
    "UserPrediction": {
      "title": "UserPrediction",
      "description": "Predicción de un usuario para un partido específico",
      "type": "object",
      "properties": {
        "matchId": { "type": "string", "description": "ID del partido" },
        "homeScore": { "type": "number", "description": "Goles equipo local" },
        "awayScore": { "type": "number", "description": "Goles equipo visitante" },
        "updatedAt": { "type": "string", "format": "date-time", "description": "Fecha de última actualización" }
      },
      "required": ["matchId", "homeScore", "awayScore"]
    },
    "ActualMatch": {
      "title": "ActualMatch",
      "description": "Resultado oficial de un partido sincronizado desde la API",
      "type": "object",
      "properties": {
        "id": { "type": "string", "description": "ID del partido" },
        "homeScore": { "type": "number", "description": "Goles reales equipo local" },
        "awayScore": { "type": "number", "description": "Goles reales equipo visitante" },
        "status": { "type": "string", "description": "Estado del partido (FT, LIVE, etc)" },
        "updatedAt": { "type": "string", "format": "date-time", "description": "Sincronizado el..." }
      },
      "required": ["id", "homeScore", "awayScore", "status"]
    },
    "League": {
      "title": "League",
      "description": "Una liga o grupo de amigos para competir en la quiniela",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "name": { "type": "string" },
        "creatorId": { "type": "string" },
        "creatorName": { "type": "string" },
        "memberUids": { "type": "array", "items": { "type": "string" } },
        "createdAt": { "type": "string", "format": "date-time" },
        "isPrivate": { "type": "boolean" },
        "competition": { "type": "string", "enum": ["WC", "CL"], "description": "El torneo que usa esta quiniela (WC o CL)" },
        "actualBestPlayerName": { "type": "string", "description": "Nombre del mejor jugador seleccionado por super admin" },
        "actualBestPlayerTeam": { "type": "string", "description": "Nombre de la selección/club del mejor jugador" },
        "actualBestPlayerFlag": { "type": "string", "description": "Bandera de la selección/club del mejor jugador" },
        "actualBestGoalkeeperName": { "type": "string", "description": "Nombre del mejor portero seleccionado por super admin" },
        "actualBestGoalkeeperTeam": { "type": "string", "description": "Nombre de la selección/club del mejor portero" },
        "actualBestGoalkeeperFlag": { "type": "string", "description": "Bandera de la selección/club del mejor portero" }
      },
      "required": ["id", "name", "creatorId", "memberUids", "competition"]
    },
    "AdminConfig": {
      "title": "AdminConfig",
      "description": "Configuración de permisos y límites para administradores de ligas",
      "type": "object",
      "properties": {
        "email": { "type": "string", "description": "Correo electrónico del administrador" },
        "role": { "type": "string", "enum": ["admin", "superadmin"], "description": "Rol de administración" },
        "maxLeaguesAllowed": { "type": "number", "description": "Número de quinielas que tiene permiso de crear" }
      },
      "required": ["email", "role", "maxLeaguesAllowed"]
    },
    "AdminRequest": {
      "title": "AdminRequest",
      "description": "Solicitud de acceso para convertirse en administrador de la plataforma",
      "type": "object",
      "properties": {
        "uid": { "type": "string", "description": "ID del usuario solicitante" },
        "email": { "type": "string", "description": "Email del usuario" },
        "displayName": { "type": "string", "description": "Nombre del usuario" },
        "photoURL": { "type": "string", "description": "Foto de perfil" },
        "status": { "type": "string", "enum": ["pending", "approved", "rejected"], "description": "Estado de la solicitud" },
        "notified": { "type": "boolean", "description": "Si el usuario ya fue notificado de la aprobación" },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["uid", "email", "status"]
    },
    "ContactRequest": {
      "title": "ContactRequest",
      "description": "Formularios de contacto recibidos en la plataforma",
      "type": "object",
      "properties": {
        "id": { "type": "string", "description": "ID del formulario" },
        "name": { "type": "string", "description": "Nombre del cliente" },
        "email": { "type": "string", "description": "Correo electrónico del cliente" },
        "phone": { "type": "string", "description": "Teléfono de contacto del cliente" },
        "message": { "type": "string", "description": "Mensaje o comentarios" },
        "createdAt": { "type": "string", "format": "date-time", "description": "Fecha de contacto" }
      },
      "required": ["id", "name", "email", "phone"]
    }
  },
  "firestore": {
    "/contactRequests/{requestId}": {
      "schema": "ContactRequest",
      "description": "Formularios de contacto de clientes para PGSimple"
    },
    "/adminRequests/{requestId}": {
      "schema": "AdminRequest",
      "description": "Solicitudes de acceso de nuevos administradores"
    },
    "/admins/{adminId}": {
      "schema": "AdminConfig",
      "description": "Lista de administradores autorizados y sus límites"
    },
    "/results/{matchId}": {
      "schema": "ActualMatch",
      "description": "Resultados oficiales sincronizados"
    },
    "/leagues/{leagueId}": {
      "schema": "League",
      "description": "Definición de las ligas"
    },
    "/users/{userId}": {
      "schema": "UserProfile",
      "description": "Perfiles de usuario y estadísticas"
    },
    "/users/{userId}/predictions/{matchId}": {
      "schema": "UserPrediction",
      "description": "Predicciones individuales por partido"
    }
  }
}
